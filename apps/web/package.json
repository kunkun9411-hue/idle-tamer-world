{
  "name": "@idle-tamer/web",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "ui:audit": "playwright test e2e/ui-layout-audit.spec.ts",
    "ui:capture": "playwright test --config=playwright.capture.config.ts",
    "check:content": "vitest run src/game/content-contract.test.ts"
  },
  "dependencies": {
    "@idle-tamer/content": "workspace:*",
    "@idle-tamer/contracts": "workspace:*",
    "@idle-tamer/game-core": "workspace:*"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "typescript": "^5.9.2",
    "vite": "^7.0.6",
    "vitest": "^3.2.4"
  }
}
