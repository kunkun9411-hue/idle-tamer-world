{
  "name": "@idle-tamer/database",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "exports": "./src/index.ts",
  "scripts": {
    "build": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:integration": "vitest run src/integration.test.ts",
    "db:migrate": "node-pg-migrate --migrations-dir migrations up",
    "db:rollback": "node-pg-migrate --migrations-dir migrations down",
    "db:seed": "tsx src/seed.ts",
    "db:verify-restore": "tsx src/verify-restored-database.ts"
  },
  "dependencies": {
    "@idle-tamer/contracts": "workspace:*",
    "node-pg-migrate": "^9.0.0",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/pg": "^8.15.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
